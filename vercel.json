{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/api/carrito",
      "dest": "/api/carrito.js"
    },
    {
      "src": "/api/procesar-pago",
      "dest": "/api/procesar-pago.js"
    },
    {
      "src": "/api/crear-preferencia",
      "dest": "/api/crear-preferencia.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}